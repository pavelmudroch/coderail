#!/usr/bin/env sh

set -eu

script_path=$0

while [ -L "$script_path" ]; do
    script_dir=$(
        CDPATH= cd -- "$(dirname "$script_path")"
        pwd
    )
    link_target=$(readlink "$script_path")

    case "$link_target" in
        /*) script_path=$link_target ;;
        *) script_path=$script_dir/$link_target ;;
    esac
done

SCRIPT_DIR=$(
    CDPATH= cd -- "$(dirname "$script_path")"
    pwd
)

ROOT_DIR=$(
    CDPATH= cd -- "$SCRIPT_DIR/.."
    pwd
)

usage() {
    cat <<'EOF'
Usage:
  cr [options] <command>

Options:
  -h, --help            Show this help message and exit
  --version             Show version information and exit
  --work-dir=<dir>, --work-dir <dir>
                        Specify the working directory for commands 'init', 'ticket', 'test', and 'check'

Commands:
    upgrade             Upgrade this cli tool to a different version
    install             Install instructions for specific agent-based tool
    clear               Clear installed instructions for specific agent-based tool
    init                Initialize a new project in the working directory
    ticket              Ticket management for the project in the working directory
    test                Run tests for the project in the working directory
    check               Run checks for the project in the working directory
EOF
}

error() {
    echo "error: $*" >&2
    echo >&2
    usage >&2
    exit 1
}

version() {
    echo "cr version 0.2.0"
}

require_no_args() {
    [ "$#" -eq 0 ] || error "unexpected argument: $1"
}

set_work_dir() {
    [ "$work_dir_set" -eq 0 ] || error "--work-dir provided multiple times"
    [ -n "$1" ] || error "--work-dir requires a non-empty value"

    work_dir=$1
    work_dir_set=1
}

run_command() {
    command=$1
    script="$ROOT_DIR/lib/$command.sh"

    [ -f "$script" ] || error "$command is not implemented"

    if [ "$uses_work_dir" -eq 1 ]; then
        [ -d "$work_dir" ] || error "--work-dir is not a directory: $work_dir"
        (
            cd "$work_dir"
            sh "$script"
        )
    else
        sh "$script"
    fi
}

work_dir=.
work_dir_set=0
uses_work_dir=0

[ "$#" -gt 0 ] || error "missing command"

while [ "$#" -gt 0 ]; do
    case "$1" in
        -h|--help)
            shift
            require_no_args "$@"
            usage
            exit 0
            ;;
        --version)
            shift
            require_no_args "$@"
            version
            exit 0
            ;;
        --work-dir=*)
            set_work_dir "${1#--work-dir=}"
            shift
            ;;
        --work-dir)
            shift
            [ "$#" -gt 0 ] || error "--work-dir requires a value"
            set_work_dir "$1"
            shift
            ;;
        upgrade|install|clear)
            command=$1
            shift
            require_no_args "$@"
            [ "$work_dir_set" -eq 0 ] || error "--work-dir is not valid for $command"
            run_command "$command"
            exit 0
            ;;
        init|ticket|test|check)
            command=$1
            shift
            require_no_args "$@"
            uses_work_dir=1
            run_command "$command"
            exit 0
            ;;
        --*)
            error "unknown option: $1"
            ;;
        *)
            error "unknown command: $1"
            ;;
    esac
done

error "missing command"
